# Flow Labs Environment Variables Template
# Copy this file to .env and fill in the values below with your own Supabase project details.
# DO NOT commit the actual .env file to version control.

# The unique identifier for your Supabase project (found in Project Settings -> General -> Reference ID)
VITE_SUPABASE_PROJECT_ID="your_supabase_project_id"

# The URL to your Supabase project API (found in Project Settings -> API)
VITE_SUPABASE_URL="https://your_supabase_project_id.supabase.co"

# The public ""anon"" key that is safe to be exposed in the browser (found in Project Settings -> API)
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_anon_key"

# The secret service role key used for backend administrative tasks (KEEP THIS SECRET!)
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# Optional maintenance script values (used by create-blocked-user.js)
BLOCKED_USER_EMAIL="blocked.user@example.com"
BLOCKED_USER_PASSWORD="ChangeMe@123"
BLOCKED_USER_FULL_NAME="Blocked User"
BLOCKED_USER_PROFESSION="student"

# Optional maintenance script values (used by fix-admin-profile.js)
MAIN_ADMIN_EMAIL="admin@flowlab.connect"
